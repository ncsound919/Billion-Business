{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL (e.g., https://grader-prod.up.railway.app)",
      "required": true
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/**": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
